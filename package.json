{
  "name": "@sibis/valeiot-sdk",
  "version": "0.11.5",
  "description": "Valeiot software development kit.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/test.ts"
  },
  "keywords": [
    "valeiot",
    "sibis"
  ],
  "author": "Sibis",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sibis-repos/valeiot-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/sibis-repos/valeiot-sdk/issues"
  },
  "homepage": "https://github.com/sibis-repos/valeiot-sdk#readme",
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "tsx": "^4.20.4"
  },
  "files": [
    "dist"
  ]
}
